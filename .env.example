# install_was.sh 실행 시 모든 값이 자동 생성됩니다.
# 수동으로 설정할 경우 아래 항목을 채워주세요.

DB_PASSWORD=
SECRET_KEY=
ADMIN_PASSWORD=
LISTEN_PORT=80

# ── 서비스 영향도 알림 (선택) ────────────────────────────────────────────────
# 미설정 시 알림은 웹 UI에만 표시됩니다. 임계값은 기본값이 있어 비워도 됩니다.
# ALERTS_ENABLED=true
# ALERT_BUCKET_MINUTES=10
# ALERT_BASELINE_DAYS=7
# ALERT_MAD_K=4.0
# ALERT_FAIL_RATE_FLOOR=0.05
# ALERT_LOGIN_FAIL_RATE_FLOOR=0.30
# ALERT_THROUGHPUT_DROP=0.5
# 메일 알림
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=soltrace@example.com
# SMTP_TLS=true
# ALERT_EMAIL_TO=ops1@example.com,ops2@example.com
# 웹훅 알림 (Slack/사내 시스템 등 JSON POST 수신 URL)
# ALERT_WEBHOOK_URL=https://hooks.example.com/soltrace
