[daemon]
# ────────────────────────────────────────────────────────────────
# WAS 연결
# ────────────────────────────────────────────────────────────────

# WAS 서버 주소 (http/https 모두 가능)
was_url = http://soltrace.mbone.net

# HTTP 연결 타임아웃 (초) - 네트워크 지연 감안하여 15초 권장
http_timeout = 15

# ────────────────────────────────────────────────────────────────
# proftpd 로그 파일 경로
# ────────────────────────────────────────────────────────────────

transfer_log = /usr/service/logs/proftpd/TransferLog
extended_log = /usr/service/logs/proftpd/ExtendedAllLog

# ────────────────────────────────────────────────────────────────
# 전송 성능
# ────────────────────────────────────────────────────────────────

# 한 번에 전송할 최대 건수
# - 로그 발생량이 적다면 50~100 권장
# - 대용량(초당 수십 건 이상)이면 200~500으로 조정
batch_size = 100

# 로그 파일 폴링 주기 (초)
# - 5초: 준실시간 / 30초: 자원 절약 모드
# - FTP 서버 부하가 높으면 10~30으로 낮출 것
poll_interval = 5

# ────────────────────────────────────────────────────────────────
# 재전송 정책
# ────────────────────────────────────────────────────────────────

# 최대 재시도 횟수 (코드 고정값: 3회, 이 값은 현재 미사용)
retry_max = 3

# 재시도 간격 (초) - WAS 회복 대기 시간
retry_delay = 10

# ────────────────────────────────────────────────────────────────
# 버퍼 (전송 실패 시 임시 저장)
# ────────────────────────────────────────────────────────────────

# 실패 항목 저장 경로
buffer_file = /var/lib/soltrace/buffer.jsonl

# 버퍼 최대 보관 줄 수 (초과 시 오래된 항목부터 삭제)
# - 디스크 용량 보호 목적, 0 = 무제한
max_buffer_lines = 50000

# ────────────────────────────────────────────────────────────────
# 하트비트
# ────────────────────────────────────────────────────────────────

# WAS에 장비 생존 신호 전송 주기 (초)
# - 너무 짧으면 WAS 부하 증가 / 30~60초 권장
heartbeat_interval = 30

# ────────────────────────────────────────────────────────────────
# 상태 파일 (위치 추적, 중복 전송 방지)
# ────────────────────────────────────────────────────────────────

state_dir = /var/lib/soltrace

# ────────────────────────────────────────────────────────────────
# 로그
# ────────────────────────────────────────────────────────────────

log_file  = /var/log/soltrace-daemon.log

# DEBUG: 전송 건수 등 상세 출력 / INFO: 기본 / WARNING: 이상 시만
log_level = INFO
